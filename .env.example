# Copy to .env.local for local development (never commit secrets).

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/checkion

# ─── Auth (NextAuth) ──────────────────────────────────────────────────────
# Min 32 chars in production (see auth.ts).
AUTH_SECRET=
# Public URL of the app (OAuth/email callbacks).
AUTH_URL=http://localhost:3333

# ─── App URLs ─────────────────────────────────────────────────────────────
# Subpath deployment (e.g. /checkion): set so client fetches hit the right origin path.
# Prefer a path only. If a full URL is provided, CHECKION will use only its pathname.
# NEXT_PUBLIC_APP_BASE_URL=
# Optional: external register link when using PLEXON SSO.
# NEXT_PUBLIC_PLEXON_REGISTER_URL=

# ─── PLEXON SSO (optional) ─────────────────────────────────────────────────
# PLEXON_AUTH_URL=
# PLEXON_SERVICE_SECRET=

# ─── Admin / ops ───────────────────────────────────────────────────────────
# Bearer token for admin API routes (scripts / integrations).
# CHECKION_ADMIN_API_KEY=
# Comma-separated user ids that may list all domain scans; or enable all authenticated:
# CHECKION_GLOBAL_DOMAIN_SCAN_USER_IDS=
# CHECKION_GLOBAL_DOMAIN_SCAN_ALL_AUTHENTICATED=0

# ─── LLM API keys (enable what you use) ────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_GEMINI_API_KEY=
# GOOGLE_API_KEY=

# ─── LLM models / tuning (optional overrides) ─────────────────────────────
# OPENAI_MODEL=gpt-5.4-nano
# OPENAI_SUGGEST_MODEL=gpt-4o-mini
# UX_CHECK_CLAUDE_MODEL=
# PAGE_CLASSIFY_CLAUDE_MODEL=
# PAGE_CLASSIFY_MAX_TOKENS=
# PAGE_TOPIC_ROLLUP_REFINE_CLAUDE_MODEL=
# PAGE_TOPIC_ROLLUP_REFINE_MAX_TOKENS=
# CHECKION_DISABLE_PAGE_TOPIC_ROLLUP_REFINE=

# ─── Rate limiting ─────────────────────────────────────────────────────────
# Optional Redis — shared counters across multiple app instances (e.g. horizontal scale).
# If unset, limits are in-memory per Node process only.
# REDIS_URL=redis://redis:6379
# Scan-style APIs (default bucket): max requests per window per key.
# RATE_LIMIT_SCAN_MAX=10
# RATE_LIMIT_SCAN_WINDOW_MS=60000
# Registration: max POST /api/auth/register per IP per window (default 5 / 15 min).
# RATE_LIMIT_REGISTER_MAX=5
# RATE_LIMIT_REGISTER_WINDOW_MS=900000

# ─── Scanner debug logs (verbose axe / CLS / journey traces) ───────────────
# CHECKION_SCAN_DEBUG=0

# ─── Puppeteer ─────────────────────────────────────────────────────────────
# PUPPETEER_PROTOCOL_TIMEOUT_MS=600000

# ─── Domain crawl ──────────────────────────────────────────────────────────
# DOMAIN_SCAN_CONCURRENCY=12
# DOMAIN_SCAN_DELAY_MS=500

# ─── Screenshots (local or S3) ─────────────────────────────────────────────
# SCREENSHOT_STORAGE=local
# SCAN_SCREENSHOTS_PATH=./data/screenshots
# SCREENSHOT_S3_BUCKET=
# S3_BUCKET=
# SCREENSHOT_S3_PREFIX=screenshots
# SCREENSHOT_AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── SERP / rank tracking ──────────────────────────────────────────────────
# SERP_API_KEY=
# SERP_API_PROVIDER=serper
# SERP_API_BASE=

# ─── AUDION audience layer (comprehensive project report, chapter 06) ───────
# Set on CHECKION (outbound). Same secret as CHECKION_INBOUND_SERVICE_TOKEN on AUDION API.
# Must point at the AUDION Next.js BFF: {origin}{optional-basePath}/api
# Examples:
#   AUDION_API_BASE_URL=https://audion.projects-a.plygrnd.tech/api
#   AUDION_API_BASE_URL=https://audion.projects-a.plygrnd.tech/audion/api  # when NEXT_PUBLIC_BASE_PATH=/audion
# AUDION_SERVICE_TOKEN=

# ─── Optional integrations ─────────────────────────────────────────────────
# GOOGLE_PAGESPEED_API_KEY=
# MCP_SERVER_URL=
# UX_JOURNEY_AGENT_URL=
# GEO_EEAT_SERVICE_URL=
# SALIENCY_SERVICE_URL=
# SALIENCY_USE_AI=
# SALIENCY_USE_SUM=
# SALIENCY_LLM_REGIONS=
# SALIENCY_VISION_PROVIDER=
# OPENAI_SALIENCY_MODEL=

# ─── Design system / build (Docker/Coolify) ────────────────────────────────
# DS_BASE=../msqdx-design-system/packages

# ─── Usage reporting (optional) ────────────────────────────────────────────
# Same vars as PLEXON if reporting to PLEXON.
