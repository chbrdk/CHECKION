# CHECKION Saliency Service – SUM backend (website/UI-optimized heatmaps)
# Uses SUM (Saliency Unification through Mamba) with condition=3 (User Interface).
# Same API as main.py; CHECKION calls SALIENCY_SERVICE_URL so point it to this app.
FROM python:3.10-slim-bookworm

WORKDIR /app

# Build deps for mamba-ssm / causal-conv1d (optional; may use wheels)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    build-essential \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Clone SUM (no weights yet – see entrypoint or volume)
RUN git clone --depth 1 https://github.com/Arhosseini77/SUM.git SUM
RUN mkdir -p SUM/net/pre_trained_weights

# PyTorch CPU-only (smaller image; for GPU use --index-url https://download.pytorch.org/whl/cu121)
RUN pip install --no-cache-dir --timeout 600 \
    --extra-index-url https://download.pytorch.org/whl/cpu \
    torch==2.1.0 torchvision==0.16.0 torchaudio==2.1.0

# causal-conv1d + mamba-ssm in SUM require numpy<2; skip CUDA build for CPU-only (no nvcc)
RUN pip install --no-cache-dir 'numpy<2'
ENV CAUSAL_CONV1D_SKIP_CUDA_BUILD=TRUE
ENV CAUSAL_CONV1D_FORCE_BUILD=TRUE
ENV MAMBA_SKIP_CUDA_BUILD=TRUE
ENV MAMBA_FORCE_BUILD=TRUE
RUN pip install --no-cache-dir --timeout 600 -r SUM/requirements.txt

# opencv-python pulls in libGL (GUI); headless variant works in server containers
RUN pip uninstall -y opencv-python 2>/dev/null || true \
    && pip install --no-cache-dir opencv-python-headless==4.6.0.66

# Our API deps + gdown (for optional Google Drive download in entrypoint)
COPY requirements-sum.txt .
RUN pip install --no-cache-dir -r requirements-sum.txt gdown

COPY main_sum.py selective_scan_cpu_stub.py .
COPY entrypoint-sum.sh .
RUN chmod +x entrypoint-sum.sh

EXPOSE 8000

ENTRYPOINT ["./entrypoint-sum.sh"]
CMD ["python", "main_sum.py"]
